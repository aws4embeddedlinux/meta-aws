From 79153b50faf0bc84b3e41b6a287e7366d1c33f74 Mon Sep 17 00:00:00 2001
From: Thomas Roos <throos@amazon.de>
Date: Mon, 22 Jun 2026 15:51:13 -0400
Subject: [PATCH] amazon-kvs-webrtc-sdk: disable download of kvs-common-lws

Upstream-Status: Inappropriate [OE-specific, disables network fetch during build]
---
 CMakeLists.txt | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 1500d3c17b..1b540032a6 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -312,6 +312,7 @@ if(BUILD_DEPENDENCIES OR BUILD_WEBSOCKETS OR BUILD_SRTP OR BUILD_USRSCTP)
   message(STATUS "Finished building dependencies.")
 endif()
 
+if(BUILD_DEPENDENCIES)
 # building kvsCommonLws also builds kvspic
 set(BUILD_ARGS
         -DCMAKE_BUILD_TYPE=${CMAKE_BUILD_TYPE}
@@ -324,6 +325,7 @@ set(BUILD_ARGS
         -DPARALLEL_BUILD=${PARALLEL_BUILD}
         -DCMAKE_C_FLAGS=${CMAKE_C_FLAGS})
 build_dependency(kvsCommonLws ${BUILD_ARGS})
+endif()
 
 ############# find dependent libraries ############
 
