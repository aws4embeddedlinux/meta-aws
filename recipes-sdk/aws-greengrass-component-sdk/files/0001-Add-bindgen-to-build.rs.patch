From 1cc3cb45b603c40e7e594ef1223e4eff7035d44d Mon Sep 17 00:00:00 2001
From: Thomas Roos <throos@amazon.de>
Date: Thu, 27 Nov 2025 12:49:26 +0000
Subject: [PATCH] aws-greengrass-component-sdk: use bindgen to correct create

Upstream-Status: Pending
---
 rust/Cargo.toml |  1 +
 rust/build.rs   | 42 ++++++++++++++++++++++++++++++++++++++++++
 2 files changed, 43 insertions(+)

diff --git a/rust/Cargo.toml b/rust/Cargo.toml
index ab2f67e..0e8d846 100644
--- a/rust/Cargo.toml
+++ b/rust/Cargo.toml
@@ -11,6 +11,7 @@ categories = ["api-bindings"]
 
 [build-dependencies]
 cc = "1"
+bindgen = "0.72"
 
 [profile.release]
 strip = true
diff --git a/rust/build.rs b/rust/build.rs
index d6737f4..21b2f27 100644
--- a/rust/build.rs
+++ b/rust/build.rs
@@ -16,6 +16,47 @@ fn main() {
     let project_root =
         PathBuf::from(&manifest_dir).parent().unwrap().to_path_buf();
 
+    bindgen::Builder::default()
+        .header(
+            PathBuf::from(&manifest_dir)
+                .join("wrapper.h")
+                .to_str()
+                .unwrap(),
+        )
+        .clang_arg(format!("-I{}", project_root.join("include").display()))
+        .default_enum_style(bindgen::EnumVariation::Rust {
+            non_exhaustive: false,
+        })
+        .generate_inline_functions(true)
+        .enable_function_attribute_detection()
+        .disable_nested_struct_naming()
+        .derive_default(true)
+        .generate_comments(false)
+        .use_core()
+        .generate_cstr(true)
+        .sort_semantically(true)
+        .allowlist_function("gg_.*")
+        .allowlist_function("ggipc_.*")
+        .allowlist_type("Gg.*")
+        .allowlist_type("GgIpc.*")
+        .allowlist_var("GG_.*")
+        .blocklist_type("timespec")
+        .raw_line("#![allow(non_upper_case_globals)]")
+        .raw_line("#![allow(non_camel_case_types)]")
+        .raw_line("#![allow(non_snake_case)]")
+        .raw_line("#![allow(dead_code)]")
+        .raw_line("#![allow(clippy::pedantic)]")
+        .raw_line("use core::ffi::c_long;")
+        .raw_line("#[repr(C)]")
+        .raw_line("#[derive(Debug, Copy, Clone, Default)]")
+        .raw_line("pub struct timespec { pub tv_sec: c_long, pub tv_nsec: c_long }")
+        .raw_line("pub const GG_OBJ_NULL: GgObject = unsafe { core::mem::zeroed() };")
+        .layout_tests(false)
+        .generate()
+        .unwrap()
+        .write_to_file(PathBuf::from(&manifest_dir).join("src/c.rs"))
+        .unwrap();
+
     let mut src_files = Vec::new();
     let mut dirs = vec![project_root.join("src")];
     while let Some(dir) = dirs.pop() {
@@ -60,6 +101,7 @@ fn main() {
 
     build.compile("gg-sdk");
 
+    println!("cargo:rerun-if-changed=wrapper.h");
     println!("cargo:rerun-if-changed=../src");
     println!("cargo:rerun-if-changed=../include");
     println!("cargo:rerun-if-changed=../priv_include");
