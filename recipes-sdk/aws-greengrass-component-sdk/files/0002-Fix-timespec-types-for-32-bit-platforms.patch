From c1e0678d99ccc66b6e03f0d7d880ecd39314d61c Mon Sep 17 00:00:00 2001
From: Thomas Roos <throos@amazon.de>
Date: Thu, 27 Nov 2025 12:49:26 +0000
Subject: [PATCH] aws-greengrass-component-sdk: use bindgen to correct create

Upstream-Status: Pending
---
 rust/src/ipc.rs | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/rust/src/ipc.rs b/rust/src/ipc.rs
index a78648c..ccedd12 100644
--- a/rust/src/ipc.rs
+++ b/rust/src/ipc.rs
@@ -3,7 +3,7 @@
 // SPDX-License-Identifier: Apache-2.0
 
 use std::{
-    env, ffi,
+    env, ffi::{self, c_long},
     marker::PhantomData,
     mem, ptr, result, slice, str,
     sync::{Mutex, OnceLock},
@@ -547,8 +547,8 @@ impl Sdk {
                 t.duration_since(std::time::UNIX_EPOCH).unwrap_or_default();
             #[expect(clippy::cast_possible_wrap)]
             c::timespec {
-                tv_sec: duration.as_secs() as i64,
-                tv_nsec: i64::from(duration.subsec_nanos()),
+                tv_sec: duration.as_secs() as c_long,
+                tv_nsec: duration.subsec_nanos() as c_long,
             }
         });
 
