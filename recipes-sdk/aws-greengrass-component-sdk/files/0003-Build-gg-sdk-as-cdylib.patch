---
 rust/Cargo.toml | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/rust/Cargo.toml b/rust/Cargo.toml
index 0e8d846..5520625 100644
--- a/rust/Cargo.toml
+++ b/rust/Cargo.toml
@@ -9,6 +9,9 @@ readme = "../README.md"
 keywords = ["aws", "greengrass", "iot"]
 categories = ["api-bindings"]
 
+[lib]
+crate-type = ["cdylib", "rlib"]
+
 [build-dependencies]
 cc = "1"
 bindgen = "0.72"
